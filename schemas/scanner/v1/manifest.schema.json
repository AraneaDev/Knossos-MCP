{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knossos.local/schemas/scanner/v1/manifest.schema.json",
  "title": "Knossos scanner manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "protocol_version",
    "output_schema_version",
    "languages",
    "file_extensions",
    "capabilities"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "protocol_version": { "const": "1.0" },
    "output_schema_version": { "const": "1.0" },
    "languages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "file_extensions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "capabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" }
    }
  }
}
