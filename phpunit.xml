<?xml version="1.0" encoding="UTF-8"?>
<!--
  One PHP suite, run by `composer test` and by Infection. It covers all of
  tests/phpunit, including the MCP transport/concurrency/HTTP tests. There is
  deliberately no default/unit split: the previous two-suite layout let a
  narrowed testsuite selection silently skip every test under tests/phpunit/Mcp
  (the most integration-heavy tests in the tree), which hid real gaps.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/phpunit/bootstrap.php"
         colors="true"
         failOnRisky="true"
         failOnWarning="false"
         cacheDirectory=".phpunit.cache">
    <testsuites>
        <testsuite name="knossos">
            <directory>tests/phpunit</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
</phpunit>
