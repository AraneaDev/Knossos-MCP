<?xml version="1.0" encoding="UTF-8"?>
<!--
  The single PHP suite, run by `composer test`. The `default` testsuite covers
  all of tests/phpunit (the ported run.php behaviour plus the original planner
  tests); `unit` remains as the narrower Infection scope until Task 12 widens
  Infection to all of src.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/phpunit/bootstrap.php"
         colors="true"
         failOnRisky="true"
         failOnWarning="false"
         cacheDirectory=".phpunit.cache">
    <testsuites>
        <testsuite name="default">
            <directory>tests/phpunit</directory>
            <exclude>tests/phpunit/Mcp</exclude>
        </testsuite>
        <testsuite name="unit">
            <directory>tests/phpunit/Mcp</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
</phpunit>
