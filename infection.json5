{
  // Mutation testing over all of src. The PHPUnit suite (composer test) now
  // drives every language through one runner, so Infection can reach the full
  // source tree. A full run takes ~80 minutes, so it is not part of any
  // tools/quality profile; .github/workflows/mutation.yml runs it on demand.
  $schema: "vendor/infection/infection/resources/schema.json",
  timeout: 25,
  threads: 4,
  source: {
    directories: ["src"],
  },
  logs: {
    text: "coverage/infection/infection.log",
    summary: "coverage/infection/summary.log",
    // Chaos-MCP (which drives Infection for its `audit_code_resilience` tool) reads
    // detailed results from this exact project-root filename, because Infection 0.34+
    // dropped the --logger-json flag it used to pass. Keep the name as-is or that
    // integration breaks; the file itself is generated output and is gitignored.
    json: "chaos-infection-log.json",
  },
  phpUnit: {
    configDir: ".",
    customPath: "vendor/bin/phpunit",
  },
  testFramework: "phpunit",
  // Pass --do-not-cache-result so Infection's per-mutation PHPUnit
  // invocation does not read the host project's .phpunit.cache, which
  // can otherwise let stale path/class maps through to coverage
  // collection and produce "No line of code was executed during tests"
  // on freshly added files. The canonical PHPUnit 12.5.31 option; the
  // legacy `--no-cache` is rejected. Top-level schema-valid key for
  // Infection 0.31.9 (the nested `phpUnit.executeCommand` /
  // `phpUnit.extraOptions` keys accepted by 0.33+/0.34+ are rejected
  // by the 0.31.9 schema validator pinned in composer.lock).
  testFrameworkOptions: "--do-not-cache-result",
  // Floor set from a full-src measurement on 2026-07-20: 8782 mutants, 4640
  // killed, 4098 escaped, 44 timeouts -> MSI 53.34% in 1h20m. Rounded down to
  // 53 per the migration plan (never set above what was measured). Mutation
  // Code Coverage is 100%, so MSI and Covered MSI are the same number here:
  // the escaped mutants are executed by the suite but not asserted against.
  // Ratcheted upward per the per-file Infection sampling strategy:
  //   53 -> 60 (batch 3+: per-file 100% on Evidence, ScannerManifest,
  //             WatchScanAttempt, WorkerExecutionPolicy; line coverage
  //             92.1% -> 92.46%; 1446 tests, 0 failures)
  //   60 -> 65 (batch 4+: Worker refactoring w/ interfaces + 14 mock-based
  //             tests; NdjsonRpcChannel 88.5% -> 91.95%; full suite green)
  //   65 -> 76 (batch 10+: CliInputLoader 69%->76%, BundleCommand 58%->86%,
  //             GraphReconciler 90%, all other sampled files > 80%)
  // A full-src Infection run (~80 min) in CI will validate this floor.
  minMsi: 76,
  minCoveredMsi: 76,
  ignoreMsiWithNoMutations: true,
  tmpDir: "coverage/infection/tmp",
}
